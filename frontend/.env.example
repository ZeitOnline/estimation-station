# Copy to `.env` to change auth behaviour. All optional.
#
# VITE_AUTH_MODE (client-side login UX):
#   off   (default) — no login, type a name. Local dev / Phase 1.
#   mock            — simulate a logged-in ZEIT user (demo the gate, no real SSO).
#   oidc            — real ZEIT SSO (needs a registered Keycloak client, below).
VITE_AUTH_MODE=off

# Only used when VITE_AUTH_MODE=oidc:
VITE_OIDC_AUTHORITY=https://openid.zeit.de/realms/zeit-online
VITE_OIDC_CLIENT_ID=estimation-station

# --- Realtime WebSocket ---
# The realtime server is now part of this SvelteKit app: the browser connects
# to the same origin on `/poker-ws`, so no separate URL is needed.
# Optional override to point the client at a different host:
# VITE_WS_URL=ws://localhost:5173/poker-ws

# --- Realtime server-side auth (only when running the WS in oidc mode) ---
# These are read by the server process (NOT VITE_-prefixed, never sent to the
# browser). Set AUTH_MODE=oidc to verify tokens on connect and enforce the
# allow-rule before a socket may join.
# AUTH_MODE=off
# OIDC_ISSUER=https://openid.zeit.de/realms/zeit-online
# OIDC_JWKS_URL=
# OIDC_AUDIENCE=
# ALLOWED_EMAIL_DOMAINS=zeit.de
# ALLOWED_GROUP=planning-poker
