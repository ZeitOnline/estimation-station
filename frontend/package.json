{
	"name": "estimation-station",
	"version": "0.1.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV=development vite dev --host",
		"build": "vite build && node esbuild.server.js",
		"preview": "vite preview",
		"start": "node build/server.js",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "npm run test:unit -- --run",
		"test:unit": "vitest",
		"copy:zds": "cp node_modules/@zeitonline/design-system/design-system.css ./src/lib/styles/styles-zds.css",
		"copy:icons": "rm -rf ./src/components/icons/svg && cp -r node_modules/@zeitonline/icons/svg ./src/components/icons/svg"
	},
	"dependencies": {
		"@biomejs/biome": "^2.5.4",
		"@zeitonline/design-system": "^0.4.1",
		"@zeitonline/icons": "^0.1.9",
		"jose": "^6.2.3",
		"oidc-client-ts": "^3.5.0",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.0.0",
		"@types/ws": "^8.18.1",
		"esbuild": "^0.28.0",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.0.0",
		"jsdom": "^29.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.5",
		"tslib": "^2.8.1",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.0",
		"vitest": "^4.0.0"
	}
}
