# Copy to `.env` to change auth behaviour. All optional.
#
# VITE_AUTH_MODE:
#   off   (default) — no login, type a name. Local dev / Phase 1.
#   mock            — simulate a logged-in ZEIT user (demo the gate, no real SSO).
#   oidc            — real ZEIT SSO (needs a registered Keycloak client, below).
VITE_AUTH_MODE=off

# Only used when VITE_AUTH_MODE=oidc:
VITE_OIDC_AUTHORITY=https://openid.zeit.de/realms/zeit-online
VITE_OIDC_CLIENT_ID=planning-poker

# Realtime WebSocket server (already set by `npm run dev`):
# VITE_WS_URL=ws://localhost:8080
